# Multi-stage build for MCPChecker runner image
#
# This image provides:
# - mcpchecker binary (built from source)
# - Python 3.11 for aggregation scripts
# - Node.js for MCP protocol support (if needed by mcpchecker)
#
# Build: podman build -t quay.io/rhecosystemappeng/mcpchecker-runner:latest .
# Push:  podman push quay.io/rhecosystemappeng/mcpchecker-runner:latest

# Stage 1: Build mcpchecker from source
FROM golang:1.22-alpine AS builder

RUN apk add --no-cache git

WORKDIR /build
RUN git clone --depth 1 https://github.com/mcpchecker/mcpchecker.git .
RUN CGO_ENABLED=0 GOOS=linux go build -ldflags="-s -w" -o /mcpchecker ./cmd/mcpchecker

# Stage 2: Runtime image with Python and mcpchecker
FROM registry.access.redhat.com/ubi9/python-311:9.6

USER root

# Copy mcpchecker binary
COPY --from=builder /mcpchecker /usr/local/bin/mcpchecker
RUN chmod +x /usr/local/bin/mcpchecker

# Install Node.js for MCP protocol support
RUN dnf install -y nodejs npm && dnf clean all

# Install Python dependencies for aggregation
RUN pip install --no-cache-dir pydantic pyyaml

# Verify installations
RUN mcpchecker --version || echo "mcpchecker installed" && \
    python --version && \
    node --version

# Set working directory
WORKDIR /workspace

# Default to non-root user for OpenShift compatibility
USER 1001

# Default command shows help
CMD ["mcpchecker", "--help"]
