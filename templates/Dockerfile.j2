ARG BASE_IMAGE
FROM ${BASE_IMAGE}

COPY instruction.md .
COPY tests/ /tests/
{% if has_claude_md %}
COPY CLAUDE.md /workspace/CLAUDE.md
{% endif %}
{% if has_supportive %}
COPY supportive/ /workspace/supportive/
{% endif %}
{% if has_scripts %}
COPY scripts/ /workspace/scripts/
{% endif %}
{% for src, dest in copy_pairs %}
COPY {{ src }}/ {{ dest }}/
{% endfor %}
