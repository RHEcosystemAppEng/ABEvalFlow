#!/bin/bash

# Run test_outputs.py via pytest with CTRF reporting.
# Do not use set -e: we need to capture the exit code and write the reward file
# regardless of whether tests pass or fail.
uvx \
  --with pytest==8.4.1 \
  --with pytest-json-ctrf==0.3.5 \
  pytest --ctrf /logs/verifier/ctrf.json /tests/test_outputs.py -rA

TEST_EXIT=$?

{% if has_llm_judge %}
# LLM judge is informational only — its output is captured in /logs but does
# not affect the reward signal or the verifier exit code.
uv run --with anthropic /tests/llm_judge.py || echo "WARNING: llm_judge.py failed (non-fatal)"
{% endif %}

CTRF_FILE="/logs/verifier/ctrf.json"
if [ -f "$CTRF_FILE" ]; then
  REWARD=$(python3 -c "
import json, sys
try:
    data = json.load(open('$CTRF_FILE'))
    s = data['results']['summary']
    total = s.get('tests', 0)
    passed = s.get('passed', 0)
    print(f'{passed / total:.4f}' if total > 0 else '0')
except Exception:
    print('1' if $TEST_EXIT == 0 else '0')
")
else
  REWARD=$([ $TEST_EXIT -eq 0 ] && echo "1" || echo "0")
fi

echo "$REWARD" > /logs/verifier/reward.txt
exit $TEST_EXIT
