FROM registry.access.redhat.com/ubi9/python-312:latest

ARG INSTALL_CLAUDE_CODE=false
ARG HARBOR_REPO=https://github.com/RHEcosystemAppEng/skills_eval_corrections.git
ARG HARBOR_REF=main

USER 0
RUN curl -LsSf https://astral.sh/uv/0.9.7/install.sh | env UV_INSTALL_DIR=/usr/local/bin sh
RUN mkdir -p /installed-agent && chmod 777 /installed-agent
RUN if [ "$INSTALL_CLAUDE_CODE" = "true" ]; then npm install -g @anthropic-ai/claude-code; fi
RUN mkdir -p /workspace && chown 1001:0 /workspace && chmod 775 /workspace

# Pre-install Harbor and dependencies (saves ~10 min per eval run)
RUN pip install --no-cache-dir \
    "git+${HARBOR_REPO}@${HARBOR_REF}" \
    "kubernetes>=32.0.0" \
    pydantic \
    pyyaml

USER 1001

WORKDIR /workspace
